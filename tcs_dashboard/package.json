{
  "name": "tcs-dashboard-assets",
  "private": true,
  "version": "0.0.0",
  "description": "Build pipeline for precompiled JSX assets shipped to the browser.",
  "scripts": {
    "build": "babel assets --only 'assets/*.jsx' --out-dir assets/dist --presets=@babel/preset-react --no-babelrc --source-maps=false --extensions .jsx --out-file-extension .js"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.0",
    "@babel/core": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
